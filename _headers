# =============================================================================
# 805lifeguard.com — Cloudflare Pages _headers
# Updated: 2026-05-07
# Note: CSP intentionally omitted — Cloudflare injects scripts automatically
# (cloudflareinsights.com beacon, email-decode.min.js) that would require
# constant CSP maintenance. Other security headers fully active.
# =============================================================================

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 0
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

/*.html
  Cache-Control: public, max-age=3600, must-revalidate

/images/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.woff
  Cache-Control: public, max-age=31536000, immutable

/*.ttf
  Cache-Control: public, max-age=31536000, immutable

/sitemap.xml
  Cache-Control: no-cache
  Content-Type: application/xml; charset=utf-8

/robots.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

/llms.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

/site.webmanifest
  Cache-Control: public, max-age=86400
  Content-Type: application/manifest+json

# =============================================================================
# Subdomain noindex rules removed in this update.
#
# The previous rules targeted https://admin.805companies.com/* etc., but a
# Cloudflare Pages _headers file only applies to responses served by the
# project it ships with. The 805lifeguard.com Pages project never serves
# requests to those subdomains, so the rules had no effect.
#
# Subdomain noindex will be configured in Phase 2 of the portal migration,
# directly on each subdomain's Pages project.
#
# Note on X-XSS-Protection: explicitly set to "0" rather than the legacy
# "1; mode=block". Modern browsers ignore this header; "0" is the current
# OWASP recommendation for the legacy XSS auditor.
# =============================================================================
