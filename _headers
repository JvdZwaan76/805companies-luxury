# =============================================================================
# 805lifeguard.com — Cloudflare Pages _headers
# Updated: 2026-05-07
# Note: CSP intentionally omitted — Cloudflare injects scripts automatically
# (cloudflareinsights.com beacon, email-decode.min.js) that would require
# constant CSP maintenance. Other security headers fully active.
# =============================================================================

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 0
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

/*.html
  Cache-Control: public, max-age=3600, must-revalidate

/images/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=3600, must-revalidate

/js/*
  Cache-Control: public, max-age=3600, must-revalidate

# Consent banner — legal/compliance content, must be updateable.
# Must appear AFTER /css/* and /js/* wildcards. Cloudflare Pages _headers
# MERGES headers from all matching rules (comma-joined), so we use the
# documented detach syntax (! Cache-Control) to remove the inherited
# wildcard value, then set the correct one.
# Ref: https://developers.cloudflare.com/pages/configuration/headers/#detach-a-header
# Ref: cloudflare-cache-audit-findings-2026-05-27.md
# DO NOT add 'immutable' or extend TTL beyond 1 hour without review.
/css/cookie-consent.css
  ! Cache-Control
  Cache-Control: public, max-age=3600, must-revalidate

/js/cookie-consent.js
  ! Cache-Control
  Cache-Control: public, max-age=3600, must-revalidate

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.woff
  Cache-Control: public, max-age=31536000, immutable

/*.ttf
  Cache-Control: public, max-age=31536000, immutable

/sitemap.xml
  Cache-Control: no-cache
  Content-Type: application/xml; charset=utf-8

/robots.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

/llms.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

/site.webmanifest
  Cache-Control: public, max-age=86400
  Content-Type: application/manifest+json

# =============================================================================
# Subdomain noindex rules removed in this update.
#
# The previous rules targeted https://admin.805companies.com/* etc., but a
# Cloudflare Pages _headers file only applies to responses served by the
# project it ships with. The 805lifeguard.com Pages project never serves
# requests to those subdomains, so the rules had no effect.
#
# Subdomain noindex will be configured in Phase 2 of the portal migration,
# directly on each subdomain's Pages project.
#
# Note on X-XSS-Protection: explicitly set to "0" rather than the legacy
# "1; mode=block". Modern browsers ignore this header; "0" is the current
# OWASP recommendation for the legacy XSS auditor.
# =============================================================================

# =============================================================================
# Staging noindex rule
# Added: 2026-05-08
#
# This rule scopes to the staging branch alias URL ONLY:
# https://staging.805companies-luxury.pages.dev/*
#
# Why this works (read carefully before editing):
#
# 1. Cloudflare Pages _headers files match against the request hostname.
#    Absolute-URL patterns (with https://) match the Host header literally.
#
# 2. The branch alias `staging.805companies-luxury.pages.dev` is served by
#    THIS Pages project (805companies-luxury), unlike admin.805companies.com
#    etc. which live on different projects. So the rule actually fires.
#
# 3. Production hostnames (805lifeguard.com, www.805lifeguard.com) do NOT
#    match this pattern. Even if this file is merged to main, production
#    is unaffected — the rule is dead code on production deployments.
#
# DO NOT modify the path pattern on this rule without understanding all of
# the above. Removing the absolute URL (e.g. changing to /*) would apply
# noindex to PRODUCTION and de-list 805lifeguard.com from Google.
# =============================================================================

https://staging.805companies-luxury.pages.dev/*
  X-Robots-Tag: noindex, nofollow, noarchive
